{
  "manifest_version": 3,
  "name": "AI Email Reply Assistant",
  "version": "1.0",
  "description": "Generate AI-powered email replies using Gemini",
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Email Assistant"
  },
  "permissions": [
    "storage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ]
}